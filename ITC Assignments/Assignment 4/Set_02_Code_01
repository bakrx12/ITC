#include<iostream>
using namespace std;

int main()
{
    int value = 0, i = 1;
    int pCount = 0, nCount = 0, oCount = 0, eCount = 0;

    while (i <= 10)
    {
        cout << "Enter Integer " << i << ": ";
        cin >> value;
        i++;


        if (value > 0)
        {
            pCount++;
        }
        if (value < 0)
        {
            nCount++;
        }
        if (value %2 == 0)
        {
            eCount++;
        }
        if(value%2 != 0)
        {
            oCount++;
        }

    }

    cout <<endl<< "Count of Positive values is " << pCount;
    cout <<endl<< "Count of Negative values is " << nCount;
    cout <<endl<< "Count of Even values is " << eCount;
    cout <<endl<< "Count of Odd values is " << oCount;
    
    
    

}
